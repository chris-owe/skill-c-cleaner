{
  "_schema": "CleanSight v6.1 app signature database",
  "_description": "已知应用程序的缓存/数据路径签名。每个条目定义扫描时检测什么、在哪、能否清理/迁移。欢迎社区贡献 PR 添加新软件！",
  "_usage": "扫描脚本自动读取此文件,检测电脑上存在哪些已知应用。用户可通过 user-custom.json 扩展自己的软件。",

  "categories": {
    "_order": ["dev_tools", "ides", "browsers", "im_apps", "office", "input_methods", "security", "virtualization", "games", "media", "cloud_storage", "rogue_software", "ai_tools", "system"],

    "dev_tools": {
      "description": "开发工具类 - 包管理器、构建工具的缓存和数据",
      "apps": [
        { "name": "npm", "detect_paths": ["%LOCALAPPDATA%\\npm-cache"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "npm_config_cache", "migration_value_template": "{TARGET_DRIVE}\\dev-cache\\npm", "clean_cmd": "npm cache clean --force" },
        { "name": "node-gyp", "detect_paths": ["%LOCALAPPDATA%\\node-gyp\\Cache"], "cleanable": true, "migratable": true, "migration_method": "symlink" },
        { "name": "pip", "detect_paths": ["%LOCALAPPDATA%\\pip\\cache"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "PIP_CACHE_DIR", "clean_cmd": "pip cache purge" },
        { "name": "Yarn", "detect_paths": ["%LOCALAPPDATA%\\Yarn\\Cache"], "cleanable": true, "migratable": true, "migration_method": "yarn_config", "migration_key": "cacheFolder", "clean_cmd": "yarn cache clean" },
        { "name": "pnpm", "detect_paths": ["%LOCALAPPDATA%\\pnpm\\store", "%LOCALAPPDATA%\\pnpm\\content-v2"], "cleanable": true, "migratable": true, "migration_method": "pnpm_config", "migration_key": "store-dir", "clean_cmd": "pnpm store prune" },
        { "name": "NuGet", "detect_paths": ["%USERPROFILE%\\.nuget\\packages"], "cleanable": "cautious", "migratable": true, "migration_method": "config_file", "migration_key": "NuGet.Config:globalPackagesFolder", "note": "删除后VS打开方案会重新下载" },
        { "name": "Cargo", "detect_paths": ["%USERPROFILE%\\.cargo\\registry", "%USERPROFILE%\\.cargo\\git"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "CARGO_HOME", "clean_cmd": "cargo cache --autoclean" },
        { "name": "Maven", "detect_paths": ["%USERPROFILE%\\.m2\\repository"], "cleanable": "cautious", "migratable": true, "migration_method": "config_file", "migration_key": "settings.xml:localRepository", "note": "删除后构建时重新下载" },
        { "name": "Gradle", "detect_paths": ["%USERPROFILE%\\.gradle\\caches"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "GRADLE_USER_HOME", "clean_cmd": "gradle cleanBuildCache" },
        { "name": "conda", "detect_paths": ["%USERPROFILE%\\miniconda3\\pkgs", "%USERPROFILE%\\anaconda3\\pkgs", "%LOCALAPPDATA%\\conda\\pkgs"], "cleanable": true, "migratable": false, "clean_cmd": "conda clean --all" },
        { "name": "Go modules", "detect_paths": ["%USERPROFILE%\\go\\pkg\\mod"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "GOMODCACHE", "clean_cmd": "go clean -modcache" },
        { "name": "npx", "detect_paths": ["%LOCALAPPDATA%\\npm-cache\\_npx"], "cleanable": true, "migratable": false },
        { "name": "Android SDK", "detect_paths": ["%LOCALAPPDATA%\\Android\\Sdk"], "cleanable": false, "migratable": true, "migration_method": "env_var", "migration_key": "ANDROID_HOME" },
        { "name": "Unity", "detect_paths": ["%LOCALAPPDATA%\\Unity\\cache", "%USERPROFILE%\\AppData\\LocalLow\\Unity"], "cleanable": true, "migratable": false },
        { "name": "Haskell Stack", "detect_paths": ["%APPDATA%\\stack"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "STACK_ROOT" },
        { "name": "Ruby gems", "detect_paths": ["%USERPROFILE%\\.gem"], "cleanable": true, "migratable": true, "migration_method": "env_var", "migration_key": "GEM_HOME" }
      ]
    },

